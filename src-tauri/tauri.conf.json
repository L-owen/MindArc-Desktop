{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MindArc",
  "version": "0.3.0",
  "identifier": "com.mindarc.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MindArc — 心有所念，落笔成篇",
        "width": 960,
        "height": 720,
        "minWidth": 600,
        "minHeight": 500,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
